# Copy this file to .env and fill in at least one key.
# If both keys are empty, the app still runs but will return no researched events.

# OpenAI Responses API key (used by default model)
OPENAI_API_KEY=

# Google AI Studio API key (used when model is deep-research-pro-preview-12-2025)
GOOGLE_API_KEY=

# Optional server port
PORT=3000
